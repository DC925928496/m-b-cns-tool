<Window x:Class="MbCnsTool.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="骑砍2 Mod 汉化工具"
        Width="1200"
        Height="820"
        MinWidth="980"
        MinHeight="680"
        Background="#F7F8FA"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Padding" Value="14" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E5E8EE" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,10,8" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#1F2937" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D8DCE3" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="#D8DCE3" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserReorderColumns" Value="True" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="IsReadOnly" Value="False" />
            <Setter Property="GridLinesVisibility" Value="None" />
            <Setter Property="RowHeaderWidth" Value="0" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="220" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Mod 根目录" />
                <TextBox x:Name="ModPathTextBox" Grid.Row="0" Grid.Column="1" Style="{StaticResource InputTextBoxStyle}" />
                <Button Grid.Row="0" Grid.Column="2" Content="选择目录" Click="OnPickModDirectory" />

                <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="汉化包输出" />
                <TextBox x:Name="OutputPathTextBox" Grid.Row="1" Grid.Column="1" Style="{StaticResource InputTextBoxStyle}" IsReadOnly="True" />
                <Button Grid.Row="1" Grid.Column="2" Content="自定义" Click="OnPickOutputDirectory" />

                <StackPanel Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,2,0,8">
                    <CheckBox x:Name="ScanDllCheckBox" Content="扫描 DLL（仅 TextObject 字面量）" Margin="0,0,16,0" VerticalAlignment="Center" />
                    <TextBlock VerticalAlignment="Center" Foreground="#6B7280" Text="提示：严格安全优先，硬编码注入仅对目标游戏版本生效。" />
                </StackPanel>

                <WrapPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3">
                    <Button x:Name="ScanButton" Content="扫描" Click="OnScan" />
                    <Button x:Name="TranslateButton" Content="开始翻译" Click="OnTranslate" IsEnabled="False" />
                    <Button x:Name="SaveButton" Content="保存记录" Click="OnSaveProject" IsEnabled="False" />
                    <Button x:Name="PackageButton" Content="打包" Click="OnPackage" IsEnabled="False" />
                </WrapPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="0,12,0,12" Style="{StaticResource CardStyle}">
            <DataGrid x:Name="EntriesDataGrid" ItemsSource="{Binding}" SelectionUnit="FullRow">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="所属文件" Binding="{Binding DisplaySourceFile}" IsReadOnly="True" Width="260" />
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" IsReadOnly="True" Width="200" />
                    <DataGridTextColumn Header="text" Binding="{Binding SourceText}" IsReadOnly="True" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextWrapping" Value="Wrap" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="译文" Binding="{Binding TargetText, UpdateSourceTrigger=PropertyChanged}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextWrapping" Value="Wrap" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                        <DataGridTextColumn.EditingElementStyle>
                            <Style TargetType="TextBox">
                                <Setter Property="TextWrapping" Value="Wrap" />
                                <Setter Property="AcceptsReturn" Value="True" />
                                <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
                            </Style>
                        </DataGridTextColumn.EditingElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}">
            <TextBox x:Name="LogTextBox"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     IsReadOnly="True"
                     FontFamily="Consolas"
                     FontSize="12" />
        </Border>
    </Grid>
</Window>
