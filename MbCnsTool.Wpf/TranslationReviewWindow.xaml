<Window x:Class="MbCnsTool.Wpf.TranslationReviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="翻译对比编辑"
        Width="1200"
        Height="760"
        MinWidth="960"
        MinHeight="620"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Margin="0,0,0,8"
                   Foreground="#4B5563"
                   Text="源文只读，译文可编辑。保存后会同步写回翻译缓存，后续同名 Mod 再次翻译会优先复用。"
                   TextWrapping="Wrap" />

        <DataGrid x:Name="ReviewDataGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column"
                  IsReadOnly="False"
                  ItemsSource="{Binding Entries}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="分类" Binding="{Binding Category}" IsReadOnly="True" Width="90" />
                <DataGridTextColumn Header="来源文件" Binding="{Binding RelativePath}" IsReadOnly="True" Width="220" />
                <DataGridTextColumn Header="字段路径" Binding="{Binding FieldPath}" IsReadOnly="True" Width="220" />
                <DataGridTextColumn Header="源文" Binding="{Binding SourceText}" IsReadOnly="True" Width="*" />
                <DataGridTextColumn Header="译文（可编辑）" Binding="{Binding TargetText, UpdateSourceTrigger=PropertyChanged}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2"
                    Margin="0,10,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button Width="120" Height="32" Margin="0,0,8,0" Content="取消" Click="OnCancel" />
            <Button Width="140" Height="32" Content="保存并关闭" Click="OnSave" />
        </StackPanel>
    </Grid>
</Window>
